[Unit]
Description=Jarvis Next.js frontend
After=network.target jarvis-backend.service

[Service]
Type=simple
WorkingDirectory=/home/john/development/jarvis/frontend
Environment=PATH=/home/john/.nvm/versions/node/v24.18.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/home/john/.nvm/versions/node/v24.18.0/bin/npm run dev -- --hostname 127.0.0.1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=jarvis.target
